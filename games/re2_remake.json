{
    "id": "re2_remake",
    "display_name": "Resident Evil 2 Remake",
    "config_format": "ini",
    "config_file": "re2_config.ini",
    "steam_app_id": "883710",
    "steam_folder_names": ["RESIDENT EVIL 2  BIOHAZARD RE2", "RESIDENT EVIL 2 BIOHAZARD RE2", "Resident Evil 2"],
    "userdata_config": false,
    "process_names": ["re2.exe"],
    "process_path_match": "RESIDENT EVIL 2",
    "borderless_only_mode": true,
    "config_keys": {
        "fullscreen": {
            "section": "RenderConfig",
            "key": "FullScreenMode",
            "windowed_value": "false",
            "fullscreen_value": "true"
        },
        "width": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float",
            "default": "(0.000000,0.000000)",
            "readonly": true
        },
        "height": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float_second",
            "readonly": true
        }
    },
    "disable_fso": true,
    "clip_cursor_to_window": true,
    "notes": "RE2 Remake : mode 'retirer bordures uniquement'. L'utilisateur configure le jeu en fenetre depuis le menu du jeu (Options > Affichage), ScreenForge retire juste les bordures pour un rendu propre. Confinement souris actif pour eviter les clics sur le bureau."
}
