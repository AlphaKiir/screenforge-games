{
    "id": "re3_remake",
    "display_name": "Resident Evil 3 Remake",
    "config_format": "ini",
    "config_file": "re3_config.ini",
    "steam_app_id": "952060",
    "steam_folder_names": ["RESIDENT EVIL 3  BIOHAZARD RE3", "RESIDENT EVIL 3 BIOHAZARD RE3", "Resident Evil 3", "RE3"],
    "userdata_config": false,
    "process_names": ["re3.exe"],
    "process_path_match": "RE3",
    "config_keys": {
        "fullscreen": {
            "section": "RenderConfig",
            "key": "FullScreenMode",
            "windowed_value": "false",
            "fullscreen_value": "true"
        },
        "width": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float",
            "default": "(0.000000,0.000000)"
        },
        "height": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float_second"
        }
    },
    "extra_cfg_lines": {
        "RenderConfig": {
            "WindowMode": "Normal"
        },
        "Render": {
            "Capability": "DirectX11"
        }
    },
    "cfg_set_readonly": true,
    "disable_fso": true,
    "enforce_native_resolution": true,
    "notes": "RE3 Remake : re3_config.ini dans dossier jeu. DX11 + cfg lecture seule + FSO desactive + display watcher (force resolution native contre DXGI mode switch)."
}
