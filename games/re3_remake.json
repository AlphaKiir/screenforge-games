{
    "id": "re3_remake",
    "display_name": "Resident Evil 3 Remake",
    "config_format": "ini",
    "config_file": "re3_config.ini",
    "steam_app_id": "952060",
    "steam_folder_names": ["RESIDENT EVIL 3  BIOHAZARD RE3", "RESIDENT EVIL 3 BIOHAZARD RE3", "Resident Evil 3", "RE3"],
    "userdata_config": false,
    "process_names": ["re3.exe"],
    "process_path_match": "RE3",
    "borderless_only_mode": true,
    "config_keys": {
        "fullscreen": {
            "section": "RenderConfig",
            "key": "FullScreenMode",
            "windowed_value": "false",
            "fullscreen_value": "true"
        },
        "width": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float",
            "default": "(0.000000,0.000000)",
            "readonly": true
        },
        "height": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float_second",
            "readonly": true
        }
    },
    "disable_fso": true,
    "clip_cursor_to_window": true,
    "notes": "RE3 Remake : mode 'retirer bordures uniquement'. L'utilisateur configure le jeu en fenetre depuis le menu du jeu (Options > Affichage), ScreenForge retire juste les bordures pour un rendu propre. Confinement souris actif pour eviter les clics sur le bureau."
}
