{
    "id": "re4_remake",
    "display_name": "Resident Evil 4 Remake",
    "config_format": "ini",
    "config_file": "local_config.ini",
    "steam_app_id": "2050650",
    "steam_folder_names": ["RESIDENT EVIL 4  BIOHAZARD RE4", "RESIDENT EVIL 4 BIOHAZARD RE4", "Resident Evil 4"],
    "userdata_config": false,
    "process_names": ["re4.exe"],
    "process_path_match": "RESIDENT EVIL 4",
    "config_keys": {
        "fullscreen": {
            "section": "RenderConfig",
            "key": "FullScreenMode",
            "windowed_value": "false",
            "fullscreen_value": "true"
        },
        "width": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float",
            "default": "(0.000000,0.000000)"
        },
        "height": {
            "section": "RenderConfig",
            "key": "NormalWindowResolution",
            "format": "tuple_float_second"
        }
    },
    "extra_cfg_lines": {
        "RenderConfig": {
            "WindowMode": "Normal"
        },
        "Render": {
            "Capability": "DirectX11"
        }
    },
    "cfg_set_readonly": true,
    "disable_fso": true,
    "enforce_native_resolution": true,
    "notes": "RE4 Remake : local_config.ini dans dossier jeu. DX11 + cfg lecture seule + FSO desactive + display watcher."
}
